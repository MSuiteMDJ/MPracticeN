# Server Configuration
PORT=3003
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:3002

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Database
DATABASE_PATH=./data/spv_duty.db

# HMRC API (Default/System-level - Optional)
# Users can configure their own credentials in the app
HMRC_API_BASE_URL=https://test-api.service.hmrc.gov.uk
HMRC_AUTH_URL=https://test-api.service.hmrc.gov.uk/oauth/token

# Security (IMPORTANT: Change these in production!)
JWT_SECRET=change_this_in_production_to_a_random_string
SESSION_SECRET=change_this_in_production_to_a_random_string

# PostgreSQL Auth Database (Production only)
# Leave empty for development (uses SQLite)
AUTH_DB_HOST=
AUTH_DB_PORT=5432
AUTH_DB_NAME=m_practice_auth
AUTH_DB_USER=mpractice
AUTH_DB_PASSWORD=

# Frontend URL (for invitation links)
FRONTEND_URL=http://localhost:3002

# Companies House API
COMPANIES_HOUSE_API_KEY=

# Logging
LOG_LEVEL=info
