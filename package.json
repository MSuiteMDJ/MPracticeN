{
  "name": "m-practice-next",
  "version": "0.1.0",
  "description": "M Practice Manager (Next) - Rebuild based on proven Customs shell",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 3002 --strictPort",
    "dev:backend": "PORT=3003 FRONTEND_URL=http://localhost:3002 pnpm --prefix backend run dev",
    "dev:all": "pnpm run dev:backend & pnpm run dev",
    "start": "pnpm run dev:all",
    "control": "open control-panel.html",
    "build": "pnpm run build:frontend && pnpm run build:backend",
    "build:frontend": "vite build",
    "build:backend": "pnpm --prefix backend run build",
    "build:all": "pnpm run build",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "format": "prettier --write src",
    "tauri": "source $HOME/.cargo/env && tauri",
    "tauri:dev": "./tauri-dev.sh",
    "tauri:build": "./tauri-build.sh"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.0.0",
    "@radix-ui/react-tabs": "^1.0.4",
    "@tauri-apps/plugin-sql": "^2.3.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "lucide-react": "^0.292.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.9.6",
    "tailwind-merge": "^2.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "terser": "^5.44.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.28.2"
}
